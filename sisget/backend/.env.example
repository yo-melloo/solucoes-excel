# SISGET BACKEND - Environment Variables Template

# [ Server ]
SERVER_PORT=8080

# [ Database ]
# Use jdbc:sqlite:sisget.db for local dev
DATABASE_URL=jdbc:sqlite:sisget.db
# DATABASE_URL=jdbc:postgresql://localhost:5432/sisget (Futuro)

DATABASE_USERNAME=admin
DATABASE_PASSWORD=admin

# [ Security ]
JWT_SECRET=sua_chave_secreta_super_longa_e_segura_aqui
JWT_EXPIRATION=3600000

# [ App Info ]
APP_NAME=SISGET_WEB
APP_VERSION=1.0.0-BETA
